# Telegram login scripts - never cache aggressively
/js/telegram-login-handler.js
  Cache-Control: public, max-age=0, must-revalidate

/js/telegram-login-handler-en.js
  Cache-Control: public, max-age=0, must-revalidate

/js/telegram-login-button.js
  Cache-Control: public, max-age=0, must-revalidate

/js/telegram-login-button-en.js
  Cache-Control: public, max-age=0, must-revalidate

# CSS files
/css/*
  Content-Type: text/css
  Cache-Control: public, max-age=31536000

# JavaScript files
/js/*
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000

# Always revalidate shared runtime config (contains popup behavior rules)
/js/config_v9.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=0, must-revalidate

# Always revalidate buy section runtime to avoid stale initialization behavior
/js/buy_section_v2026_v9.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=0, must-revalidate

# CSS files inside JS libraries (sweetalert2, cookieconsent, etc)
/js/_lib/*.css
  Content-Type: text/css
  Cache-Control: public, max-age=31536000

/js/_lib/*/*.css
  Content-Type: text/css
  Cache-Control: public, max-age=31536000

# Images
/img/*
  Cache-Control: public, max-age=31536000

# SVG images
/img/*.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=31536000

/img/*/*.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=31536000

# Fonts
/fonts/*
  Cache-Control: public, max-age=31536000

